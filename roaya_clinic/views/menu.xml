<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ROOT MENU -->
    <menuitem id="smart_clinic_root"
        name="Smart Clinic"
        sequence="10" />
    <!-- DOCTOR ACTION -->
    <record id="action_clinic_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">clinic.doctor</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- PATIENT ACTION -->
    <record id="action_clinic_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">clinic.patient</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- APPOINTMENT ACTION -->
    <record id="action_clinic_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">clinic.appointment</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- LAB ORDER ACTION -->
    <record id="action_clinic_lab_order" model="ir.actions.act_window">
        <field name="name">Lab Orders</field>
        <field name="res_model">clinic.lab_order</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- ===================================================== -->
    <!-- SMART CLINIC WEBSITE - Doctor Schedule -->
    <!-- ===================================================== -->
    <!-- DAILY CENSUS ACTION -->
    <record id="action_daily_census_wizard" model="ir.actions.act_window">
        <field name="name">Daily Census Report</field>
        <field name="res_model">daily.census.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <!-- DOCTOR SCHEDULE ACTIONS -->
    <record id="action_clinic_schedule" model="ir.actions.act_window">
        <field name="name">Doctor Schedules</field>
        <field name="res_model">clinic.schedule</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_clinic_schedule_slot" model="ir.actions.act_window">
        <field name="name">Available Slots</field>
        <field name="res_model">clinic.schedule.slot</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- SPECIALTY ACTION -->
    <record id="action_clinic_specialty" model="ir.actions.act_window">
        <field name="name">Specialties</field>
        <field name="res_model">clinic.specialty</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- API TOKEN ACTION -->
    <record id="action_api_token" model="ir.actions.act_window">
        <field name="name">API Tokens</field>
        <field name="res_model">api.token</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- MENUS -->
    <menuitem id="menu_clinic_doctor"
        name="Doctors"
        parent="smart_clinic_root"
        action="action_clinic_doctor"
        sequence="2" />
    <menuitem id="menu_clinic_patient"
        name="Patients"
        parent="smart_clinic_root"
        action="action_clinic_patient"
        sequence="3" />
    <menuitem id="menu_clinic_appointment"
        name="Appointments"
        parent="smart_clinic_root"
        action="action_clinic_appointment"
        sequence="1" />
    <!-- clinic_schedule -->
    <menuitem
        id="menu_clinic_schedule"/>
    <menuitem id="menu_clinic_schedule"
        name="Doctor Schedules"
        parent="smart_clinic_root"
        action="action_clinic_schedule"
        sequence="7" />
    <!-- Daily Census Menu -->
    <menuitem id="menu_daily_census"
        name="Daily Census Report"
        parent="smart_clinic_root"
        action="action_daily_census_wizard"
        sequence="8" />
    <!-- CONFIGURATION -->
    <menuitem id="menu_clinic_configuration"
        name="Configuration"
        parent="smart_clinic_root"
        sequence="100" />
    <menuitem id="menu_clinic_specialty"
        name="Specialties"
        parent="menu_clinic_configuration"
        action="action_clinic_specialty"
        sequence="1" />
    <menuitem id="menu_api_token"
        name="API Tokens"
        parent="menu_clinic_configuration"
        action="action_api_token"
        sequence="2" />
</odoo>