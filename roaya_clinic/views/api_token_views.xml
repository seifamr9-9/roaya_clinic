<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_api_token_tree" model="ir.ui.view">
        <field name="name">api.token.tree</field>
        <field name="model">api.token</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"
                    decoration-success="is_active"
                    decoration-danger="not is_active"
                />
                <field name="user_id" />
                <field
                    name="is_active" widget="boolean_toggle" readonly="True" />
                <field
                    name="expiry_date" widget="badge" />
                <field name="last_used" />
            </tree>
        </field>
    </record>

    <record id="view_api_token_form" model="ir.ui.view">
        <field name="name">api.token.form</field>
        <field name="model">api.token</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_regenerate_token"
                        type="object"
                        string="Regenerate Token"
                        class="btn-primary"
                        confirm="This will invalidate the current token. Continue?" />
                </header>
                <sheet>

                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" />
                        <h1>
                            <field name="name" placeholder="API Token Name" />
                        </h1>
                    </div>

                    <group string="User Information">

                        <field name="user_id" string="Assigned User" />
                        <field name="is_active" widget="boolean_toggle" />
                    </group>

                    <group string="Token Information">
                        <field name="token" readonly="1" widget="CopyClipboardChar" />
                        <field name="expiry_date" />
                        <field name="last_used" readonly="1" />
                        <field name="last_ip" readonly="1" string="Last IP" />
                    </group>


                </sheet>
            </form>
        </field>
    </record>
</odoo>