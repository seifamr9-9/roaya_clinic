<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="services_page" name="Services">
        <t t-call="website.layout">
            <div id="wrap" class="container py-5">
                <h2 class="text-center fw-bold mb-5">Our Medical Services</h2>
                <div class="row">
                    <t t-foreach="specialties" t-as="service">
                        <div class="col-lg-4 col-md-6 mb-4">
                            <div class="card h-100 p-4 border-0 shadow-sm text-center">
                                <div class="text-primary mb-3"><i class="fa fa-heartbeat fa-3x"></i></div>
                                <h4 class="fw-bold"><t t-esc="service.name"/></h4>
                                <p class="text-muted small"><t t-esc="service.description or 'Professional Medical Service'"/></p>
                                <a t-attf-href="/doctors?specialty_id={{ service.id }}" class="btn btn-sm btn-outline-primary mt-auto">View Doctors</a>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>