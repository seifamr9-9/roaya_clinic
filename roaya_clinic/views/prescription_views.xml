<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= TREE VIEW ================= -->
    <record id="view_clinic_prescription_tree" model="ir.ui.view">
        <field name="name">clinic.prescription.tree</field>
        <field name="model">clinic.prescription</field>
        <field name="arch" type="xml">
                    <tree string="Prescriptions">

            <field name="name"/>
            <field name="date"/>
            <field name="patient_id"/>
            <field name="doctor_id"/>
            <field name="medication_name"/>
            <field name="dosage"/>
            <field name="frequency"/>
            <field name="duration_days"/>

        </tree>
        </field>
    </record>

    <!-- ================= FORM VIEW ================= -->
    <record id="view_clinic_prescription_form" model="ir.ui.view">
        <field name="name">clinic.prescription.form</field>
        <field name="model">clinic.prescription</field>
        <field name="arch" type="xml">

            <form string="Prescription">

                <sheet>

                    <!-- Title -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Main Info -->
                    <group>

                        <group string="Patient Information">
                            <field name="appointment_id"/>
                            <field name="patient_id" readonly="1"/>
                            <field name="doctor_id"/>
                            <field name="date"/>
                        </group>

                        <group string="Medication Details">
                            <field name="medication_name"/>
                            <field name="dosage"/>
                            <field name="frequency"/>
                            <field name="duration_days"/>
                        </group>

                    </group>

                    <!-- Notes -->
                    <notebook>
                        <page string="Doctor Notes">
                            <field name="notes" placeholder="Write special instructions..."/>
                        </page>
                    </notebook>

                </sheet>

            </form>

        </field>
    </record>

    <!-- ================= ACTION ================= -->
    <record id="action_clinic_prescription" model="ir.actions.act_window">
        <field name="name">Prescriptions</field>
        <field name="res_model">clinic.prescription</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

</odoo>