<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_charge_tree" model="ir.ui.view">
        <field name="name">clinic.charge.tree</field>
        <field name="model">clinic.charge</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="appointment_id"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="line_type"/>
                <field name="total_amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_charge_form" model="ir.ui.view">
        <field name="name">clinic.charge.form</field>
        <field name="model">clinic.charge</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_pay"
                            type="object"
                            string="Pay"
                            class="btn-success"
                            invisible="state != 'pending'"/>
                    <button name="action_reset_to_draft"
                            type="object"
                            string="Reset Draft"
                            invisible="state == 'draft'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,pending,paid"/>
                    <button name="action_print_charge" type="object" string="Print Charge" class="btn-primary"/>
                </header>
                <sheet>
                    <group col="2" string="Basic Information">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="appointment_id"/>
                            <field name="patient_id" readonly="1"/>
                            <field name="doctor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="line_type"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                    <group col="2" string="Financial Details">
                        <group>
                            <field name="amount"/>
                            <field name="late_fee"/>
                        </group>
                        <group>
                            <field name="total_amount" readonly="1"/>
                        </group>
                    </group>
                    <group col="2" string="Payment Info">
                        <group>
                            <field name="due_date"/>
                            <field name="payment_date"/>
                        </group>
                        <group>
                            <field name="payment_method"/>
                        </group>
                    </group>
                    <group >
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_clinic_charge" model="ir.actions.act_window">
        <field name="name">Charges</field>
        <field name="res_model">clinic.charge</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>