<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="email_template_appointment_reminder" model="mail.template">
            <field name="name">Patient Appointment Reminder</field>
            <field name="model_id" ref="smart_clinic.model_clinic_appointment" />
            <field name="subject">
                Reminder: Appointment with {{ object.doctor_id.name }} on {{ object.date }}
            </field>

            <field name="email_from">
                {{ user.email_formatted }}
            </field>

            <field name="email_to">
                {{ object.patient_id.email }}
            </field>

            <field name="body_html" type="html">
                <div
                    style="margin:0; padding:0; font-size:13px; font-family:Arial, Helvetica, sans-serif;">
                    <p> Dear <strong>
                            <t t-out="object.patient_id.name" />
                        </strong>, </p>

                    <p> This is a friendly reminder that you have an upcoming appointment with <strong>
                            <t t-out="object.doctor_id.name" />
                        </strong> on <strong>
                            <t t-out="object.date" />
                        </strong>. </p>

                    <table style="border-collapse:collapse;">
                        <tr>
                            <td>
                                <strong>Doctor:</strong>
                            </td>
                            <td>
                                <t t-out="object.doctor_id.name" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Specialty: </strong>
                            </td>
                            <td>
                                <t t-out="object.specialty_id.name" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Date: </strong>
                            </td>
                            <td>
                                <t t-out="object.date" />
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Time: </strong>
                            </td>
                            <td>
                                <t t-out="object.start_time" /> - <t t-out="object.end_time" />
                            </td>
                        </tr>
                    </table>

                    <p>
                        If you need to reschedule or have any questions, please contact us before
                        your appointment.
                    </p>

                    <p>
                        We look forward to seeing you.
                    </p>

                    <p> Best regards,<br />
                        <strong>Smart Clinic</strong>
                    </p>
                </div>
            </field>

            <field name="auto_delete" eval="True" />

        </record>

        <record
            id="email_template_appointment_cancellation" model="mail.template">
            <field name="name">Patient Appointment Cancellation</field>
            <field name="model_id" ref="crm.model_crm_lead" />
            <field name="subject">
                Appointment Cancellation Notice - {{ object.doctor_id.name }}
            </field>

            <field name="email_from">
                {{ user.email_formatted }}
            </field>

            <field name="email_to">
                {{ object.patient_id.email }}
            </field>

            <field name="body_html" type="html">
                <div
                    style="margin:0; padding:0; font-size:13px; font-family:Arial, Helvetica, sans-serif;">

                    <p>Dear <strong>
                            <t t-out="object.patient_id.name" />
                        </strong>,</p>

                    <p> We regret to inform you that your appointment with <strong>
                            <t
                                t-out="object.doctor_id.name" />
                        </strong>
                        scheduled for <strong>
                            <t t-out="object.requested_appointment_datetime" />
                        </strong>
                        has been <strong
                            style="color:#cc0000;">cancelled</strong>. </p>

                    <table style="border-collapse:collapse; margin-bottom:12px;">
                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Doctor:</strong>
                            </td>
                            <td>
                                <t t-out="object.doctor_id.name" />
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Specialty:</strong>
                            </td>
                            <td>
                                <t t-out="object.specialty_id.name" />
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Date:</strong>
                            </td>
                            <td>
                                <t t-out="object.requested_appointment_datetime" />
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Time:</strong>
                            </td>
                            <td>
                                <t t-out="object.start_time" /> - <t t-out="object.end_time" />
                            </td>
                        </tr>
                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Reason:</strong>
                            </td>
                            <td>
                                <t t-out="object.rejection_reason or 'No reason provided'" />
                            </td>
                        </tr>
                    </table>

                    <p>
                        We apologize for any inconvenience this may cause. Please contact us to
                        reschedule your appointment at your earliest convenience.
                    </p>

                    <p>We look forward to serving you soon.</p>

                    <p> Best regards,<br />
                <strong>Smart Clinic</strong>
                    </p>

                </div>
            </field>

            <field name="auto_delete" eval="True" />
        </record>

        <record
            id="email_template_appointment_confirmation" model="mail.template">
            <field name="name">Patient Appointment Confirmation</field>
            <field name="model_id" ref="crm.model_crm_lead" />

            <field name="subject">
                Appointment Confirmed - {{ object.doctor_id.name }}
            </field>

            <field name="email_from">
                {{ user.email_formatted }}
            </field>

            <field name="email_to">
                {{ object.patient_id.email }}
            </field>

            <field name="body_html" type="html">
                <div
                    style="margin:0; padding:0; font-size:13px; font-family:Arial, Helvetica, sans-serif;">

                    <p> Dear <strong>
                            <t t-out="object.patient_id.name" />
                        </strong>, </p>

                    <p> We are pleased to confirm your appointment with <strong>
                            <t
                                t-out="object.doctor_id.name" />
                        </strong>. </p>

                    <table style="border-collapse:collapse; margin-bottom:12px;">
                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Doctor:</strong>
                            </td>
                            <td>
                                <t t-out="object.doctor_id.name" />
                            </td>
                        </tr>

                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Specialty:</strong>
                            </td>
                            <td>
                                <t t-out="object.specialty_id.name" />
                            </td>
                        </tr>

                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Date &amp; Time:</strong>
                            </td>
                            <td>
                                <t t-out="object.requested_appointment_datetime" />
                            </td>
                        </tr>

                        <tr>
                            <td style="padding:4px 12px 4px 0;">
                                <strong>Appointment Time:</strong>
                            </td>
                            <td>
                                <t t-out="object.start_time" /> - <t t-out="object.end_time" />
                            </td>
                        </tr>
                    </table>

                    <p>
                        If you need to reschedule or have any questions, please contact us before
                        your appointment.
                    </p>

                    <p>
                        We look forward to welcoming you and providing you with the best possible
                        care.
                    </p>

                    <p> Best regards,<br />
                <strong>Smart Clinic</strong>
                    </p>

                </div>
            </field>

            <field name="auto_delete" eval="True" />
        </record>
    </data>
</odoo>