<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_clinic_appointment" model="ir.sequence">
        <field name="name">clinic.appointment</field>
        <field name="code">clinic.appointment</field>
        <field name="prefix">APPO/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>


    <record id="seq_clinic_prescription" model="ir.sequence">
        <field name="name">Clinic Prescription</field>
        <field name="code">clinic.prescription</field>
        <field name="prefix">PRES/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>


    <record id="seq_clinic_lab_order" model="ir.sequence">
        <field name="name">Clinic Lab Order</field>
        <field name="code">clinic.lab_order</field>
        <field name="prefix">LAB/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>


    
    <record id="seq_clinic_charge" model="ir.sequence">
        <field name="name">Clinic Charge</field>
        <field name="code">clinic.charge</field>
        <field name="prefix">CHG/</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

</odoo>
