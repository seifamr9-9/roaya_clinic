<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================= REPORT ACTION ================= -->
    <record id="action_report_lab_order" model="ir.actions.report">
        <field name="name">Lab Order</field>
        <field name="model">clinic.lab_order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">roaya_clinic.report_lab_order</field>
        <field name="report_file">roaya_clinic.report_lab_order</field>
        <field name="print_report_name">'Lab Order - %s' % (object.patient_id.name)</field>
        <field name="binding_model_id" ref="model_clinic_lab_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ================= REPORT TEMPLATE ================= -->
    <template id="report_lab_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2>Lab Order</h2>

                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Patient:</strong>
                                <span t-field="doc.patient_id.name"/>
                            </div>
                            <div class="col-6">
                                <strong>Doctor:</strong>
                                <span t-field="doc.doctor_id.name"/>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <strong>Ordered Date:</strong>
                                <span t-field="doc.ordered_date"/>
                            </div>
                            <div class="col-6">
                                <strong>Appointment:</strong>
                                <span t-field="doc.appointment_id.name"/>
                            </div>
                        </div>

                        <table class="table table-bordered mt-4">
                            <thead>
                                <tr>
                                    <th>Test Type</th>
                                    <th>Urgency</th>
                                    <th>Status</th>
                                    <th>Completed Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span t-field="doc.test_type"/></td>
                                    <td><span t-field="doc.urgency"/></td>
                                    <td><span t-field="doc.state"/></td>
                                    <td><span t-field="doc.completed_date"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="mt-4" t-if="doc.description">
                            <strong>Description:</strong>
                            <p t-field="doc.description"/>
                        </div>

                        <div class="mt-4" t-if="doc.result">
                            <strong>Result:</strong>
                            <p t-field="doc.result"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>