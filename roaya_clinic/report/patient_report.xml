<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_patient_medical">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <h2>Patient Medical Summary</h2>
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Name:</strong></td>
                                <td><span t-field="o.name"/></td>
                            </tr>
                            <tr>
                                <td><strong>Date of Birth:</strong></td>
                                <td><span t-field="o.date_of_birth"/></td>
                            </tr>
                            <tr>
                                <td><strong>Gender:</strong></td>
                                <td><span t-field="o.gender"/></td>
                            </tr>
                            <tr>
                                <td><strong>Blood Type:</strong></td>
                                <td><span t-field="o.blood_type"/></td>
                            </tr>
                            <tr>
                                <td><strong>Phone:</strong></td>
                                <td><span t-field="o.phone"/></td>
                            </tr>
                            <tr>
                                <td><strong>Mobile:</strong></td>
                                <td><span t-field="o.mobile"/></td>
                            </tr>
                            <tr>
                                <td><strong>Email:</strong></td>
                                <td><span t-field="o.email"/></td>
                            </tr>
                            <tr>
                                <td><strong>Active:</strong></td>
                                <td><span t-field="o.active"/></td>
                            </tr>
                        </table>

                        <t t-if="o.allergies">
                            <h3 class="mt-4">Allergies</h3>
                            <p t-field="o.allergies" class="text-pre"/>
                        </t>

                        <h3 class="mt-4">Appointments</h3>
                        <t t-set="appointments" t-value="env['clinic.appointment'].search([('patient_id', '=', o.id)], order='date desc')"/>
                        <t t-if="appointments">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Doctor</th>
                                        <th>Specialty</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="appointments" t-as="apt">
                                        <td><span t-field="apt.date"/></td>
                                        <td><span t-field="apt.doctor_id.name"/></td>
                                        <td><span t-field="apt.specialty_id.name"/></td>
                                        <td><span t-field="apt.state"/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </t>
                        <t t-if="not appointments">
                            <p class="text-muted">No appointments recorded.</p>
                        </t>
                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>