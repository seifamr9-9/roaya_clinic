<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_create_appointment_wizard_form" model="ir.ui.view">
        <field name="name">create.appointment.wizard.form</field>
        <field name="model">create.appointment.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Appointment">
                <sheet>
                    <group string="Basic Information" col="2">
                        <group>
                            <field name="patient_id" readonly="1"/>
                            <field name="doctor_id"/>
                            <field name="specialty_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="consultation_fee" readonly="1"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <group string="Schedule">
                        <group>
                            <field name="available_slot_ids" invisible="1"/>
                            <field name="slot_id"/>
                            <field name="start_time" readonly="1"/>
                            <field name="end_time" readonly="1"/>
                            <field name="is_today" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_appointment"
                            string="Create Appointment"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>