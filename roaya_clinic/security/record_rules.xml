<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_smart_clinic" model="ir.module.category">
        <field name="name">Smart Clinic</field>
        <field name="sequence">10</field>
    </record>
    <record id="group_smart_clinic_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="category_id" ref="module_category_smart_clinic"/>
    </record>
    <record id="group_smart_clinic_receptionist" model="res.groups">
        <field name="name">Receptionist</field>
        <field name="category_id" ref="module_category_smart_clinic"/>
        <field name="implied_ids" eval="[(4, ref('group_smart_clinic_doctor'))]"/>
    </record>
    <record id="group_smart_clinic_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_smart_clinic"/>
        <field name="implied_ids" eval="[(4, ref('group_smart_clinic_receptionist'))]"/>
    </record>
    <!-- Doctor: sees only his own appointments -->
    <record id="rule_appointment_doctor_own" model="ir.rule">
        <field name="name">Appointment: Doctor sees own only</field>
        <field name="model_id" ref="model_clinic_appointment"/>
        <field name="groups" eval="[(4, ref('group_smart_clinic_doctor'))]"/>
        <field name="domain_force">[('doctor_id.user_id', '=', user.id)]</field>
    </record>
    <!-- Receptionist: sees ALL appointments -->
    <record id="rule_appointment_receptionist_all" model="ir.rule">
        <field name="name">Appointment: Receptionist sees all</field>
        <field name="model_id" ref="model_clinic_appointment"/>
        <field name="groups" eval="[(4, ref('group_smart_clinic_doctor'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
    <!-- Manager: sees ALL appointments -->
    <record id="rule_appointment_manager_all" model="ir.rule">
        <field name="name">Appointment: Manager sees all</field>
        <field name="model_id" ref="model_clinic_appointment"/>
        <field name="groups" eval="[(4, ref('group_smart_clinic_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>